# Root safety-net ignores for the monorepo.
# Each subproject (task3/, frontend/) also has its own .gitignore.

# Dependencies
node_modules/
**/node_modules/

# Environment / secrets — never commit
.env
.env.*
!**/.env.example
**/.env
**/.env.*
!**/.env.example

# Build output
dist/
build/
**/dist/
**/build/
**/.next/
**/out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.tsbuildinfo
