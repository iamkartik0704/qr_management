# --- Backend (Express) environment ---
# Copy to .env and fill in real values. Never commit the real .env.

PORT=5001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/tedx?appName=Cluster0

# Strong random secret used to sign JWTs / QR tokens (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_string

# URL of the deployed frontend, used for CORS allow-origin
FRONTEND_URL=http://localhost:3000

# Seed accounts (used by `npx tsx src/seed.ts`)
SEED_ADMIN_EMAIL=admin@tedx.com
SEED_ADMIN_PASSWORD=change_me
SEED_VOLUNTEER_EMAILS=gate1@tedx.com,gate2@tedx.com
SEED_VOLUNTEER_PASSWORD=change_me
