# --- Backend (Express) environment ---
# Copy to .env and fill in real values. Never commit the real .env.

PORT=5001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/tedx?appName=Cluster0

# Strong random secret used to sign JWTs / QR tokens (e.g. `openssl rand -hex 32`)
JWT_SECRET=change_me_to_a_long_random_string

# URL of the deployed frontend, used for CORS allow-origin
FRONTEND_URL=http://localhost:3000

# --- Email / SMTP (used to mail tickets to attendees) ---
# Optional: if SMTP_HOST is empty, ticket generation still works but no email
# is sent. Point these at ANY SMTP server — there is no per-day cap in the code.
#
# Local SMTP options with NO sending limits:
#   • MailHog   — dev/testing, captures mail in a web UI: SMTP_HOST=localhost SMTP_PORT=1025
#   • Postfix   — a real local relay on the machine:       SMTP_HOST=localhost SMTP_PORT=25
# Or use any provider's SMTP (note: providers usually DO impose daily limits).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false           # true for port 465 (implicit TLS), false otherwise
SMTP_USER=                  # leave blank if the relay needs no auth
SMTP_PASS=
SMTP_FROM=TEDxIITPatna <no-reply@tedx.com>

# Seed accounts (used by `npx tsx src/seed.ts` and on boot).
# The admin is always (re)seeded from these vars. SEED_VOLUNTEER_* is now
# OPTIONAL — it only bootstraps a few starter volunteers. The admin can create
# and remove volunteers at runtime from the dashboard, and those persist across
# restarts (seeding no longer prunes accounts that aren't listed here).
SEED_ADMIN_EMAIL=admin@tedx.com
SEED_ADMIN_PASSWORD=change_me
SEED_VOLUNTEER_EMAILS=gate1@tedx.com,gate2@tedx.com
SEED_VOLUNTEER_PASSWORD=change_me
